{
  "name": "buildbeacon",
  "displayName": "BuildBeacon",
  "description": "BuildBeacon detects when specified processes exit and sends notifications",
  "version": "0.0.1",
  "publisher": "lxb007981",
  "license":"MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/lxb007981/buildbeacon"
  },
  "engines": {
    "vscode": "^1.86.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "buildbeacon-sidebar",
          "title": "BuildBeacon",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "buildbeacon-sidebar": [
        {
          "type": "webview",
          "id": "buildbeacon-panel",
          "name": "BuildBeacon",
          "icon": "media/icon.svg"
        }
      ]
    },
    "configuration": {
      "title": "BuildBeacon",
      "properties": {
        "buildbeacon.endpoint": {
          "type": "string",
          "default": "sample_api.com",
          "description": "The endpoint URL to send POST requests to"
        },
        "buildbeacon.content": {
          "type": "string",
          "default": "build finishes",
          "description": "The content to send in the POST request"
        },
        "buildbeacon.monitoredProcess": {
          "type": "string",
          "default": "build.sh",
          "description": "The process name to monitor"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "check-types": "tsc --noEmit",
    "lint": "eslint src"
  },
  "devDependencies": {
    "@types/vscode": "^1.86.0",
    "@types/node": "22.x",
    "typescript-eslint": "^8.54.0",
    "eslint": "^9.39.2",
    "esbuild": "^0.27.2",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3"
  },
  "dependencies": {}
}
